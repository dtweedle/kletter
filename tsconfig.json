{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "sourceMap": false
  },
  "include": [
    "topo-render/src/**/*.ts",
    "topo-render/test/**/*.ts",
    "topo-editor/src/**/*.ts",
    "topo-editor/test/**/*.ts"
  ]
}
